# Database Configuration
# For SQLite (local development):
DATABASE_URL=sqlite:///./carbonsense.db

# For PostgreSQL (Docker/production):
# DATABASE_URL=postgresql://carbonsense:carbonsense@db:5432/carbonsense

# JWT Secret Key (CHANGE THIS TO A RANDOM SECRET IN PRODUCTION!)
SECRET_KEY=your-super-secret-key-change-in-production-please-use-a-long-random-string-here

# JWT Settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days in minutes

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# ==============================================
# GOOGLE CLOUD PLATFORM (GCP) SERVICES (FOR HACKATHON!)
# ==============================================
# Google Gemini API (for AI Assistant)
GOOGLE_API_KEY=your-google-gemini-api-key-here

# Google Cloud Project ID
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# Google Cloud Storage Bucket Name (for user profile images)
GOOGLE_CLOUD_STORAGE_BUCKET=your-gcs-bucket-name

# Google Maps API Key (for location-based recommendations)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Google reCAPTCHA Secret Key (for bot protection on auth)
GOOGLE_RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key-here
